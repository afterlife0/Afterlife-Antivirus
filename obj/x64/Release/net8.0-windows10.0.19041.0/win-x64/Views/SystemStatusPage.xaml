<Page x:ConnectionId='1'
    x:Class="AfterlifeWinUI.Views.SystemStatusPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent"
                        
                            >
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
        <StackPanel Spacing="20">
            <!-- Header - Animated Element 0 -->
            <StackPanel x:ConnectionId='2' x:Name="AnimHeader" Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE9F5;" FontSize="28" Foreground="{StaticResource CyanBrush}"/>
                    <TextBlock Style="{StaticResource TitleText}" Text="System Status"/>
                </StackPanel>
                <TextBlock x:ConnectionId='19' x:Name="PageSubtitle" Style="{StaticResource SubtitleText}" Text="Monitor service health and detection engines" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Service Status Row -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border x:ConnectionId='15' x:Name="AnimService1" Grid.Column="0" Style="{StaticResource GlassPanel}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1815151f" Offset="0"/>
                            <GradientStop Color="#08ffffff" Offset="0.3"/>
                            <GradientStop Color="#1812121a" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8C9;" FontSize="18" Foreground="{StaticResource CyanBrush}"/>
                            <TextBlock x:ConnectionId='18' x:Name="CoreServiceTitle" Text="Core Service" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Ellipse Width="12" Height="12" Fill="{StaticResource GreenBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="ONLINE" Foreground="{StaticResource GreenBrush}" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <Border x:ConnectionId='16' x:Name="AnimService2" Grid.Column="1" Style="{StaticResource GlassPanel}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1815151f" Offset="0"/>
                            <GradientStop Color="#08ffffff" Offset="0.3"/>
                            <GradientStop Color="#1812121a" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE99A;" FontSize="18" Foreground="{StaticResource PurpleBrush}"/>
                            <TextBlock x:ConnectionId='17' x:Name="AIEngineTitle" Text="AI Engine" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Ellipse Width="12" Height="12" Fill="{StaticResource GreenBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="ONLINE" Foreground="{StaticResource GreenBrush}" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Engine Stats Row -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border x:ConnectionId='3' x:Name="AnimEngine1" Grid.Column="0" Style="{StaticResource GlassPanel}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1815151f" Offset="0"/>
                            <GradientStop Color="#08ffffff" Offset="0.3"/>
                            <GradientStop Color="#1812121a" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock x:ConnectionId='12' x:Name="SignatureEngineLabel" Text="Signature Engine" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:ConnectionId='13' x:Name="SignatureCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PurpleBrush}"/>
                        <TextBlock x:ConnectionId='14' x:Name="SignaturesLabel" Text="Signatures" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    </StackPanel>
                </Border>
                
                <Border x:ConnectionId='4' x:Name="AnimEngine2" Grid.Column="1" Style="{StaticResource GlassPanel}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1815151f" Offset="0"/>
                            <GradientStop Color="#08ffffff" Offset="0.3"/>
                            <GradientStop Color="#1812121a" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock x:ConnectionId='9' x:Name="YaraEngineLabel" Text="YARA Engine" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:ConnectionId='10' x:Name="YaraCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource CyanBrush}"/>
                        <TextBlock x:ConnectionId='11' x:Name="RulesLabel" Text="Rules" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    </StackPanel>
                </Border>
                
                <Border x:ConnectionId='5' x:Name="AnimEngine3" Grid.Column="2" Style="{StaticResource GlassPanel}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1815151f" Offset="0"/>
                            <GradientStop Color="#08ffffff" Offset="0.3"/>
                            <GradientStop Color="#1812121a" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock x:ConnectionId='6' x:Name="AIHeuristicLabel" Text="AI Heuristic" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:ConnectionId='7' x:Name="AIModelCount" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource OrangeBrush}"/>
                        <TextBlock x:ConnectionId='8' x:Name="ModelLabel" Text="Models" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>

