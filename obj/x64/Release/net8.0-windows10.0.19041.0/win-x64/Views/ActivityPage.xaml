<Page x:ConnectionId='1'
    x:Class="AfterlifeWinUI.Views.ActivityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent"
                        
                            >
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- PAGE HEADER - Animated Element 0 -->
        <StackPanel x:ConnectionId='2' x:Name="AnimHeader" Grid.Row="0" Margin="0,16,0,16">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <FontIcon Glyph="&#xE9F9;" FontSize="28" Foreground="{StaticResource CyanBrush}"/>
                <TextBlock Style="{StaticResource TitleText}" Text="Activity Monitor"/>
            </StackPanel>
            <TextBlock x:ConnectionId='19' x:Name="PageSubtitle" Style="{StaticResource SubtitleText}" Text="View all scan history and threat detections" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- STATS BAR - Animated Element 1 -->
        <Border x:ConnectionId='3' x:Name="AnimStats" Grid.Row="1" Margin="0,0,0,20" Style="{StaticResource GlassPanel}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1815151f" Offset="0"/>
                    <GradientStop Color="#08ffffff" Offset="0.3"/>
                    <GradientStop Color="#1812121a" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock x:ConnectionId='17' x:Name="TotalEntries" Text="0" FontSize="24" FontWeight="Bold" 
                               Foreground="{StaticResource CyanBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:ConnectionId='18' x:Name="TotalEventsLabel" Text="Total Events" Foreground="{StaticResource TextSecondaryBrush}" 
                               HorizontalAlignment="Center" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock x:ConnectionId='15' x:Name="ThreatCount" Text="0" FontSize="24" FontWeight="Bold" 
                               Foreground="{StaticResource RedBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:ConnectionId='16' x:Name="ThreatsLabel" Text="Threats" Foreground="{StaticResource TextSecondaryBrush}" 
                               HorizontalAlignment="Center" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock x:ConnectionId='13' x:Name="ScanCount" Text="0" FontSize="24" FontWeight="Bold" 
                               Foreground="{StaticResource CyanBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:ConnectionId='14' x:Name="ScansLabel" Text="Scans" Foreground="{StaticResource TextSecondaryBrush}" 
                               HorizontalAlignment="Center" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock x:ConnectionId='11' x:Name="WarningCount" Text="0" FontSize="24" FontWeight="Bold" 
                               Foreground="{StaticResource OrangeBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:ConnectionId='12' x:Name="WarningsLabel" Text="Warnings" Foreground="{StaticResource TextSecondaryBrush}" 
                               HorizontalAlignment="Center" FontSize="12"/>
                </StackPanel>

                <Button x:ConnectionId='10' Grid.Column="4" x:Name="ClearLogButton" Content="Clear Log" 
                        Style="{StaticResource GlassButton}"
                                              />
            </Grid>
        </Border>

        <!-- ACTIVITY LIST - Animated Element 2 -->
        <Border x:ConnectionId='4' x:Name="AnimContent" Grid.Row="2" Style="{StaticResource GlassPanel}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1815151f" Offset="0"/>
                    <GradientStop Color="#08ffffff" Offset="0.3"/>
                    <GradientStop Color="#1812121a" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <!-- Empty State -->
                <StackPanel x:ConnectionId='5' x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE8FD;" FontSize="48" 
                              Foreground="{StaticResource TextSecondaryBrush}"
                              HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock x:ConnectionId='8' x:Name="EmptyStateTitle" Text="No activity yet" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:ConnectionId='9' x:Name="EmptyStateSubtitle" Text="Scan activity and events will appear here" 
                               Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Activity ListView -->
                <ListView x:ConnectionId='6' x:Name="ActivityList" 
                          Background="Transparent" 
                          SelectionMode="None"
                          Visibility="Collapsed">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                    CornerRadius="6" Padding="12,8" Margin="0,2">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="{Binding TimeString}" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" FontSize="11"/>
                                    
                                    <TextBlock Grid.Column="1" Text="{Binding TypeString}" 
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{Binding TypeColor}"/>
                                    
                                    <TextBlock Grid.Column="2" Text="{Binding Message}" 
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>

