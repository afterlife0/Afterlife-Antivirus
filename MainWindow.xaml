<Window
    x:Class="AfterlifeWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AfterlifeWinUI"
    Title="AFTERLiFE">

    <!-- Main Container -->
    <Grid x:Name="RootGrid" Background="{StaticResource BackgroundBrush}">
        
        <!-- Autonomous Animated Neon Orbs - Multiple orbs moving across entire window -->
        <Canvas x:Name="BackgroundCanvas" IsHitTestVisible="False">
            <!-- Orange/Yellow Gradient Orb - Top Left (like Liquid Glass Shader reference) -->
            <Ellipse x:Name="OrbOrange" Width="600" Height="600" Canvas.Left="-100" Canvas.Top="-50">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#70ff8c00" Offset="0"/>
                        <GradientStop Color="#50ff6600" Offset="0.25"/>
                        <GradientStop Color="#30ff4400" Offset="0.5"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Cyan/Blue Gradient Orb 1 - Primary -->
            <Ellipse x:Name="OrbCyan1" Width="700" Height="700" Canvas.Left="600" Canvas.Top="100">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#5500e5ff" Offset="0"/>
                        <GradientStop Color="#3500c8e0" Offset="0.25"/>
                        <GradientStop Color="#1800a0c0" Offset="0.5"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Cyan/Blue Gradient Orb 2 - Secondary -->
            <Ellipse x:Name="OrbCyan2" Width="500" Height="500" Canvas.Left="200" Canvas.Top="300">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#4000d4ff" Offset="0"/>
                        <GradientStop Color="#2800b0d0" Offset="0.3"/>
                        <GradientStop Color="#1000809a" Offset="0.6"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Purple Orb 1 - Large -->
            <Ellipse x:Name="OrbPurple1" Width="600" Height="600" Canvas.Left="800" Canvas.Top="400">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#50b026ff" Offset="0"/>
                        <GradientStop Color="#359020e0" Offset="0.3"/>
                        <GradientStop Color="#18601090" Offset="0.6"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Purple Orb 2 - Medium -->
            <Ellipse x:Name="OrbPurple2" Width="400" Height="400" Canvas.Left="100" Canvas.Top="500">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#40a020f0" Offset="0"/>
                        <GradientStop Color="#288018c0" Offset="0.35"/>
                        <GradientStop Color="#12500a80" Offset="0.65"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Magenta Orb - Accent -->
            <Ellipse x:Name="OrbMagenta" Width="450" Height="450" Canvas.Left="500" Canvas.Top="200">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#45ff26a0" Offset="0"/>
                        <GradientStop Color="#30e01880" Offset="0.3"/>
                        <GradientStop Color="#15900a50" Offset="0.6"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Green Orb - Accent -->
            <Ellipse x:Name="OrbGreen" Width="380" Height="380" Canvas.Left="400" Canvas.Top="500">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#3800ff9d" Offset="0"/>
                        <GradientStop Color="#2500e080" Offset="0.3"/>
                        <GradientStop Color="#12009050" Offset="0.6"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Blue Orb - Deep accent -->
            <Ellipse x:Name="OrbBlue" Width="550" Height="550" Canvas.Left="-50" Canvas.Top="50">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#450080ff" Offset="0"/>
                        <GradientStop Color="#300060e0" Offset="0.3"/>
                        <GradientStop Color="#150040a0" Offset="0.6"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Canvas>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- DRAGGABLE TITLE BAR - Full width at top -->
            <Grid x:Name="TitleBarDragRegion" 
                  Grid.Row="0"
                  Height="40" 
                  Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="276"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Empty draggable area over sidebar -->
                <Border Grid.Column="0" Background="Transparent"/>
                
                <!-- Empty center area - native buttons will appear on the right -->
                <Border Grid.Column="1" Background="Transparent"/>
            </Grid>

            <!-- Main content below title bar -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LIQUID GLASS SIDEBAR - Clean without fixed edge glows -->
                <Grid Grid.Column="0" Margin="16,0,0,16">
                    <!-- Main glass panel -->
                    <Border x:Name="SidebarBorder" 
                            CornerRadius="20"
                            BorderThickness="1">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#30ffffff" Offset="0"/>
                                <GradientStop Color="#18ffffff" Offset="0.5"/>
                                <GradientStop Color="#25ffffff" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        
                        <!-- Dark mode default - synced with panel transparency -->
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#231e1e32" Offset="0"/>
                                <GradientStop Color="#14ffffff" Offset="0.15"/>
                                <GradientStop Color="#0cffffff" Offset="0.5"/>
                                <GradientStop Color="#1e141428" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Title / Brand Header -->
                            <StackPanel x:Name="TitlePanel" Grid.Row="0" Margin="20,16,20,16">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="BrandAfter" Text="AFTER" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="LiFE" FontSize="28" FontWeight="Bold" Foreground="{StaticResource CyanBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Menu Label -->
                            <TextBlock x:Name="MenuLabel" Grid.Row="1" Text="MENU" FontSize="10" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextSecondaryBrush}" 
                                       Margin="20,8,20,8"/>

                            <!-- Navigation Buttons -->
                            <StackPanel Grid.Row="2" Margin="12,0">
                                <Button x:Name="NavDashboard" Click="NavDashboard_Click" 
                                        Style="{StaticResource NavButtonRect}" Tag="Active">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE80F;" FontSize="16" Margin="0,0,12,0"/>
                                        <TextBlock Text="Dashboard"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavThreats" Click="NavThreats_Click" Style="{StaticResource NavButtonRect}">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE7BA;" FontSize="16" Margin="0,0,12,0"/>
                                        <TextBlock Text="Threats"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavActivity" Click="NavActivity_Click" Style="{StaticResource NavButtonRect}">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE8FD;" FontSize="16" Margin="0,0,12,0"/>
                                        <TextBlock Text="Activity Log"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavSystemStatus" Click="NavSystemStatus_Click" Style="{StaticResource NavButtonRect}">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE9F5;" FontSize="16" Margin="0,0,12,0"/>
                                        <TextBlock Text="System Status"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavSettings" Click="NavSettings_Click" Style="{StaticResource NavButtonRect}">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE713;" FontSize="16" Margin="0,0,12,0"/>
                                        <TextBlock Text="Settings"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Status Footer Panel - clean without edge glow -->
                            <Border Grid.Row="3" Margin="12,8,12,16" Padding="14" 
                                    CornerRadius="12" BorderThickness="1">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#25ffffff"/>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <SolidColorBrush Color="#10ffffff"/>
                                </Border.Background>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Margin="0,0,10,0" 
                                                 Fill="{StaticResource GreenBrush}"/>
                                        <TextBlock x:Name="StatusText" Text="PROTECTED" 
                                                   FontWeight="Bold" FontSize="13" Foreground="{StaticResource GreenBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                        <TextBlock x:Name="SigLabel" Text="Signatures:" FontSize="11" 
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="SigCount" Text="{x:Bind ViewModel.SignatureCount, Mode=OneWay}" 
                                                   FontSize="11" Foreground="{StaticResource CyanBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock x:Name="YaraLabel" Text="YARA Rules:" FontSize="11" 
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="YaraCount" Text="{x:Bind ViewModel.YaraRuleCount, Mode=OneWay}" 
                                                   FontSize="11" Foreground="{StaticResource CyanBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock x:Name="AILabel" Text="AI Models:" FontSize="11" 
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="AICount" Text="{x:Bind ViewModel.AIModelCount, Mode=OneWay}" 
                                                   FontSize="11" Foreground="{StaticResource OrangeBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- MAIN CONTENT AREA -->
                <Grid Grid.Column="1" Margin="16,0,16,16">
                    <Frame x:Name="ContentFrame"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>

