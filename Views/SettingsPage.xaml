<Page
    x:Class="AfterlifeWinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
        <StackPanel Spacing="20">
            <!-- Header - Animated Element 0 -->
            <StackPanel x:Name="AnimHeader" Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE713;" FontSize="28" Foreground="{StaticResource CyanBrush}"/>
                    <TextBlock Style="{StaticResource TitleText}" Text="Settings"/>
                </StackPanel>
                <TextBlock x:Name="PageSubtitle" Style="{StaticResource SubtitleText}" Text="Configure protection settings and preferences" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Appearance / Theme Section -->
            <Border x:Name="AnimSection0" Style="{StaticResource GlassPanel}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1815151f" Offset="0"/>
                        <GradientStop Color="#08ffffff" Offset="0.3"/>
                        <GradientStop Color="#1812121a" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE790;" FontSize="18" Foreground="{StaticResource OrangeBrush}"/>
                        <TextBlock x:Name="AppearanceTitle" Text="Appearance" FontWeight="SemiBold" FontSize="16" Foreground="White"/>
                    </StackPanel>
                    
                    <TextBlock x:Name="ThemeLabel" Text="Theme" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                    
                    <!-- Theme Selector - Three Radio Buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <!-- System Theme -->
                        <Border x:Name="ThemeSystem" 
                                Background="#15ffffff" CornerRadius="12" Padding="16,12"
                                BorderThickness="2" BorderBrush="Transparent"
                                PointerPressed="ThemeSystem_Click">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE770;" FontSize="20" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="SystemThemeText" Text="System" Foreground="{StaticResource TextPrimaryBrush}" 
                                           VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Dark Theme -->
                        <Border x:Name="ThemeDark" 
                                Background="#15ffffff" CornerRadius="12" Padding="16,12"
                                BorderThickness="2" BorderBrush="{StaticResource CyanBrush}"
                                PointerPressed="ThemeDark_Click">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE708;" FontSize="20" Foreground="{StaticResource PurpleBrush}"/>
                                <TextBlock x:Name="DarkThemeText" Text="Dark" Foreground="{StaticResource TextPrimaryBrush}" 
                                           VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Light Theme -->
                        <Border x:Name="ThemeLight" 
                                Background="#15ffffff" CornerRadius="12" Padding="16,12"
                                BorderThickness="2" BorderBrush="Transparent"
                                PointerPressed="ThemeLight_Click">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE706;" FontSize="20" Foreground="{StaticResource OrangeBrush}"/>
                                <TextBlock x:Name="LightThemeText" Text="Light" Foreground="{StaticResource TextPrimaryBrush}" 
                                           VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <TextBlock Text="Theme changes apply immediately" 
                               Foreground="{StaticResource GreenBrush}" FontSize="11" FontStyle="Italic"/>
                </StackPanel>
            </Border>

            <!-- Real-time Protection -->
            <Border x:Name="AnimSection1" Style="{StaticResource GlassPanel}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1815151f" Offset="0"/>
                        <GradientStop Color="#08ffffff" Offset="0.3"/>
                        <GradientStop Color="#1812121a" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8C9;" FontSize="18" Foreground="{StaticResource CyanBrush}"/>
                        <TextBlock x:Name="RealTimeTitle" Text="Real-time Protection" FontWeight="SemiBold" FontSize="16" Foreground="White"/>
                    </StackPanel>
                    <ToggleSwitch x:Name="ToggleRealTime" Header="Enable real-time scanning" Toggled="ToggleRealTime_Toggled"/>
                    <ToggleSwitch x:Name="ToggleScanOnCreation" Header="Scan on file creation" Toggled="ToggleScanOnCreation_Toggled"/>
                    <ToggleSwitch x:Name="ToggleScanOnModification" Header="Scan on file modification" Toggled="ToggleScanOnModification_Toggled"/>
                </StackPanel>
            </Border>

            <!-- Detection Engines -->
            <Border x:Name="AnimSection2" Style="{StaticResource GlassPanel}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1815151f" Offset="0"/>
                        <GradientStop Color="#08ffffff" Offset="0.3"/>
                        <GradientStop Color="#1812121a" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE773;" FontSize="18" Foreground="{StaticResource GreenBrush}"/>
                        <TextBlock x:Name="DetectionTitle" Text="Detection Engines" FontWeight="SemiBold" FontSize="16" Foreground="White"/>
                    </StackPanel>
                    <ToggleSwitch x:Name="ToggleSignature" Header="Signature-based detection" Toggled="ToggleSignature_Toggled"/>
                    <ToggleSwitch x:Name="ToggleYara" Header="YARA rule matching" Toggled="ToggleYara_Toggled"/>
                    <ToggleSwitch x:Name="ToggleAI" Header="AI heuristic analysis" Toggled="ToggleAI_Toggled"/>
                </StackPanel>
            </Border>

            <!-- Scheduled Scans -->
            <Border x:Name="AnimSection3" Style="{StaticResource GlassPanel}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1815151f" Offset="0"/>
                        <GradientStop Color="#08ffffff" Offset="0.3"/>
                        <GradientStop Color="#1812121a" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE787;" FontSize="18" Foreground="{StaticResource PurpleBrush}"/>
                        <TextBlock x:Name="ScheduledTitle" Text="Scheduled Scans" FontWeight="SemiBold" FontSize="16" Foreground="White"/>
                    </StackPanel>
                    <ToggleSwitch x:Name="ToggleScheduled" Header="Enable scheduled scans" Toggled="ToggleScheduled_Toggled"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock x:Name="ScanIntervalLabel" Text="Scan interval:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <ComboBox Width="120" SelectedIndex="0">
                            <ComboBoxItem Content="1 hour"/>
                            <ComboBoxItem Content="6 hours"/>
                            <ComboBoxItem Content="12 hours"/>
                            <ComboBoxItem Content="24 hours"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
